generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum DocumentType {
  CPF
  CNPJ

  @@map("document_type")
}

model Customer {
  id           String       @id @db.Uuid
  name         String
  document     String       @unique
  documentType DocumentType @map("document_type")
  email        String?
  phone        String?
  createdAt    DateTime     @map("created_at")
  updatedAt    DateTime     @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  vehicles     Vehicle[]

  @@map("customers")
}

model Vehicle {
  id         String    @id @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  plate      String    @unique
  brand      String
  model      String
  year       Int
  createdAt  DateTime  @map("created_at")
  updatedAt  DateTime  @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  customer   Customer  @relation(fields: [customerId], references: [id])

  @@map("vehicles")
}

model RepairService {
  id          String    @id @db.Uuid
  name        String
  description String?
  priceCents  Int       @map("price_cents")
  createdAt   DateTime  @map("created_at")
  updatedAt   DateTime  @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("repair_services")
}

enum WorkOrderStatus {
  RECEIVED
  IN_DIAGNOSIS
  AWAITING_APPROVAL
  IN_EXECUTION
  FINISHED
  DELIVERED
  CANCELLED

  @@map("work_order_status")
}

enum WorkOrderItemKind {
  SERVICE
  PART

  @@map("work_order_item_kind")
}

model WorkOrder {
  id         String                   @id @db.Uuid
  customerId String                   @map("customer_id") @db.Uuid
  vehicleId  String                   @map("vehicle_id") @db.Uuid
  status     WorkOrderStatus
  totalCents Int                      @map("total_cents")
  createdAt  DateTime                 @map("created_at")
  updatedAt  DateTime                 @map("updated_at")
  items      WorkOrderItem[]
  history    WorkOrderStatusHistory[]

  @@index([status, createdAt])
  @@map("work_orders")
}

model WorkOrderItem {
  id             String            @id @db.Uuid
  workOrderId    String            @map("work_order_id") @db.Uuid
  kind           WorkOrderItemKind
  referenceId    String            @map("reference_id") @db.Uuid
  description    String
  unitPriceCents Int               @map("unit_price_cents")
  quantity       Int
  workOrder      WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("work_order_items")
}

model WorkOrderStatusHistory {
  id          String          @id @db.Uuid
  workOrderId String          @map("work_order_id") @db.Uuid
  status      WorkOrderStatus
  changedAt   DateTime        @map("changed_at")
  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("work_order_status_history")
}

enum SagaStatus {
  RUNNING
  COMPLETED
  CANCELLED

  @@map("saga_status")
}

model SagaInstance {
  workOrderId      String     @id @map("work_order_id") @db.Uuid
  status           SagaStatus
  step             String
  partsReserved    Boolean    @map("parts_reserved")
  quoteGenerated   Boolean    @map("quote_generated")
  paymentConfirmed Boolean    @map("payment_confirmed")
  createdAt        DateTime   @map("created_at")
  updatedAt        DateTime   @map("updated_at")

  @@map("saga_instances")
}
